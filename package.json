{
  "name": "co-reader",
  "version": "0.2.0",
  "description": "Intelligent reading companion — paragraph-level summarization, highlights, and cross-references",
  "private": true,
  "type": "module",
  "scripts": {
    "copy-ort": "mkdir -p public/ort && cp node_modules/onnxruntime-web/dist/ort-wasm-simd-threaded.asyncify.* node_modules/onnxruntime-web/dist/ort-wasm-simd-threaded.jsep.* public/ort/",
    "dev": "npm run copy-ort && wxt",
    "build": "npm run copy-ort && wxt build",
    "zip": "npm run copy-ort && wxt zip",
    "typecheck": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@preact/signals": "^1.3.2",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "wxt": "^0.20.20"
  }
}
